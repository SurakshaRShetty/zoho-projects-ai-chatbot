# ── Zoho OAuth Credentials ────────────────────────────────────
# Get these from https://api-console.zoho.com/
# Create a "Server-based Application"
ZOHO_CLIENT_ID=your_zoho_client_id_here
ZOHO_CLIENT_SECRET=your_zoho_client_secret_here

# The URL Zoho will redirect to after user approves (must match exactly in Zoho console)
ZOHO_REDIRECT_URI=http://localhost:8000/auth/callback

# Zoho data center base URL (use .com for global, .eu for Europe, .in for India)
ZOHO_ACCOUNTS_URL=https://accounts.zoho.com
ZOHO_API_BASE_URL=https://projectsapi.zoho.com

# ── App Security ──────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your_random_secret_key_here

# Key used to encrypt/decrypt Zoho tokens stored in the database
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=your_fernet_encryption_key_here

# How long our JWT session tokens last (in minutes)
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ── Database ──────────────────────────────────────────────────
# SQLite (default for local dev — file created automatically)
DATABASE_URL=sqlite+aiosqlite:///./zoho_chatbot.db

# ── LLM Provider ─────────────────────────────────────────────
# Choose one: "groq", "anthropic", or "openai"
LLM_PROVIDER=groq

# Groq (free) — get from https://console.groq.com/
GROQ_API_KEY=your_groq_api_key_here

# Anthropic (Claude) — get from https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# OpenAI — get from https://platform.openai.com/
OPENAI_API_KEY=your_openai_api_key_here

# Which model to use for the agents
# Groq models:     llama-3.3-70b-versatile, llama-3.1-8b-instant, gemma2-9b-it
# Anthropic models: claude-3-5-sonnet-20241022
# OpenAI models:   gpt-4o, gpt-4o-mini
LLM_MODEL=llama-3.3-70b-versatile

# ── App Settings ─────────────────────────────────────────────
APP_ENV=development
BACKEND_PORT=8000
FRONTEND_URL=http://localhost:3000

# CORS: which origins are allowed to call the backend
ALLOWED_ORIGINS=http://localhost:3000
