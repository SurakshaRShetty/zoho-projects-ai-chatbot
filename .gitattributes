# Normalize line endings to LF in the repo; convert to CRLF on Windows checkout
* text=auto

# Always LF for these (shell scripts, Python, JS/TS source)
*.py    text eol=lf
*.ts    text eol=lf
*.tsx   text eol=lf
*.js    text eol=lf
*.json  text eol=lf
*.md    text eol=lf
*.env*  text eol=lf

# Binary — never touch line endings
*.png   binary
*.jpg   binary
*.ico   binary
*.db    binary
